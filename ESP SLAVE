#include <Arduino.h>
#include <Wire.h>

// ── Konfigurasi ──────────────────────────────
#define ESP32_ADDR  0x09

int  counter     = 0;
byte responseESP = 0;

// ── Setup ─────────────────────────────────────
void setup() {
  Serial.begin(115200);
  Wire.begin();
  Wire.setClock(50000);

  Serial.println("=== STM32 I2C Master ===");
}

// ── Loop ──────────────────────────────────────
void loop() {
  // 1. Kirim counter ke ESP32
  Wire.beginTransmission(ESP32_ADDR);
  Wire.write((byte)(counter & 0xFF));
  byte err = Wire.endTransmission();

  // 2. Request balasan dari ESP32
  byte received = Wire.requestFrom(ESP32_ADDR, 1);
  if (received > 0 && Wire.available()) {
    responseESP = Wire.read();
  }

  // 3. Serial Monitor
  Serial.println("──────────────────────");
  Serial.print("TX ke ESP32  : ");
  Serial.println(counter);
  if (err == 0) {
    Serial.print("RX dari ESP32: 0x");
    Serial.println(responseESP, HEX);
    Serial.println("Status       : OK");
  } else {
    Serial.print("Status       : ERROR kode ");
    Serial.println(err);
  }

  counter++;
  if (counter > 255) counter = 0;

  delay(1000);
}
